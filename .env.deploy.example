###################################
#----------  App secret ----------#
###################################
APP_KEY=

SENTRY_LARAVEL_DSN=

DB_HOST=scraping.hub.pgsql
DB_PORT=5432
DB_DATABASE=example_app
DB_USERNAME=sail
DB_PASSWORD=password

REDIS_CLIENT=phpredis
REDIS_HOST=scraping.hub.redis
REDIS_PASSWORD=null
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=sail
AWS_SECRET_ACCESS_KEY=password
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=local
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=http://scraping.hub.minio:9000
AWS_URL=

########################################
#---------- App environments ----------#
########################################
APP_NAME=FireHub
APP_ENV=production
APP_DEBUG=false
APP_URL=
APP_LOCALE=en
APP_MAINTENANCE_DRIVER=redis

DB_CONNECTION=pgsql

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
CACHE_STORE=redis

################################################
#---------- K8s deployment variables ----------#
################################################
APP_HOST=
K8S_NAMESPACE=firehub-production
IMAGE_PULL_POLICY=Always
PHP_IMAGE=

# Workload distribution
NODE_LABEL_SELECTOR_KEY=
WEB_DEPLOYMENT_NODE_LABEL_SELECTOR_VALUE=
SCHEDULER_DEPLOYMENT_NODE_LABEL_SELECTOR_VALUE=
WORKER_DEPLOYMENT_NODE_LABEL_SELECTOR_VALUE=

# Web replicas
WEB_MIN_REPLICAS=1
WEB_MAX_REPLICAS=100

# Web resource
WEB_CPU_REQUEST=0.3
WEB_MEMORY_REQUEST=600M
WEB_CPU_LIMIT=0.5
WEB_MEMORY_LIMIT=850M
WEB_AVERAGE_CPU=70
WEB_AVERAGE_MEMORY=70

# Scheduler resource
SCHEDULER_CPU_REQUEST=0.1
SCHEDULER_MEMORY_REQUEST=256M
SCHEDULER_CPU_LIMIT=0.2
SCHEDULER_MEMORY_LIMIT=512M

# Worker replicas
WORKER_ARTICLE_BUILDING_REPLICAS=1
WORKER_DEFAULT_REPLICAS=1
WORKER_FILE_SCRAPING_REPLICAS=1
WORKER_KEYWORD_RESEARCHING_REPLICAS=1
WORKER_PAGE_SCRAPING_REPLICAS=1
WORKER_PUBLISHING_REPLICAS=1
WORKER_SCHEDULER_REPLICAS=1

# Worker resource
WORKER_CPU_REQUEST=0.1
WORKER_MEMORY_REQUEST=256M
WORKER_CPU_LIMIT=0.2
WORKER_MEMORY_LIMIT=512M

##############################
#---------- OpenAI ----------#
##############################

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT=60
OPENAI_BETA_HEADER=responses=v1

OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_DEFAULT_MODEL=gpt-5.4-mini
OPENAI_COMPATIBLE_TIMEOUT=60
OPENAI_COMPATIBLE_BETA_HEADER=

################################
#---------- Services ----------#
################################

# Fact checker
FACTCHECKER_DRIVER=openai
FACTCHECKER_OPENAI_MODEL=gpt-5.4-mini

# FileVision
FILEVISION_DRIVER=openai_compatible

# IntentResolver
INTENTRESOLVER_DRIVER=openai_compatible
INTENTRESOLVER_OPENAI_COMPATIBLE_MAX_CONTENT_LENGTH=50000
INTENTRESOLVER_OPENAI_COMPATIBLE_MAX_KEYWORDS=25
INTENTRESOLVER_OPENAI_COMPATIBLE_MAX_RESOLVE_INTENTS=8

# Page classifier
PAGECLASSIFIER_DRIVER=openai_compatible

# Page parser
PAGEPARSER_DRIVER=openai_compatible

# Scrape Policy Engine
SCRAPE_POLICY_ENGINE_DRIVER=openai_compatible

# Search engine
SEARCH_ENGINE_DRIVER=perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar
PERPLEXITY_TIMEOUT=90
PERPLEXITY_CONNECT_TIMEOUT=15

# Text embedding services
TEXT_EMBEDDING_DRIVER=openai
TEXT_EMBEDDING_OPENAI_PROVIDER=openai
TEXT_EMBEDDING_OPENAI_MODEL=text-embedding-3-small
TEXT_EMBEDDING_OPENAI_DIMENSION=1536

# Vertical Resolver
VERTICALRESOLVER_DRIVER=openai_compatible

#################################################
#---------- Synthesizer super service ----------#
#################################################

SYNTHESIZER_DRIVER=openai
SYNTHESIZER_OPENAI_IDEA_ADVISOR_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_IDEA_AUDITOR_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_IDEA_PICKER_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_RESEARCHER_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_BRIEF_BUILDER_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_OUTLINE_BUILDER_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_EDITOR_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_CRITIC_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_WRITER_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_TAGGER_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_ILLUSTRATION_DIRECTOR_MODEL=gpt-5.4-mini
SYNTHESIZER_OPENAI_ILLUSTRATOR_MODEL=gpt-image-1