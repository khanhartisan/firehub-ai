# K8s deployment environment variables
K8S_NAMESPACE=firehub-production
IMAGE_PULL_POLICY=Always
PHP_IMAGE=

# Workload distribution
NODE_LABEL_SELECTOR_KEY=
WEB_DEPLOYMENT_NODE_LABEL_SELECTOR_VALUE=
SCHEDULER_DEPLOYMENT_NODE_LABEL_SELECTOR_VALUE=
WORKER_DEPLOYMENT_NODE_LABEL_SELECTOR_VALUE=

# Web replicas
WEB_MIN_REPLICAS=1
WEB_MAX_REPLICAS=100

# Web resource
WEB_CPU_REQUEST=0.3
WEB_MEMORY_REQUEST=600M
WEB_CPU_LIMIT=0.5
WEB_MEMORY_LIMIT=850M
WEB_AVERAGE_CPU=70
WEB_AVERAGE_MEMORY=70

# Scheduler resource
SCHEDULER_CPU_REQUEST=0.1
SCHEDULER_MEMORY_REQUEST=256M
SCHEDULER_CPU_LIMIT=0.2
SCHEDULER_MEMORY_LIMIT=512M

# Worker replicas
WORKER_ARTICLE_BUILDING_REPLICAS=1
WORKER_DEFAULT_REPLICAS=1
WORKER_FILE_SCRAPING_REPLICAS=1
WORKER_KEYWORD_RESEARCHING_REPLICAS=1
WORKER_PAGE_SCRAPING_REPLICAS=1
WORKER_PUBLISHING_REPLICAS=1
WORKER_SCHEDULER_REPLICAS=1

# Worker resource
WORKER_CPU_REQUEST=0.1
WORKER_MEMORY_REQUEST=256M
WORKER_CPU_LIMIT=0.1
WORKER_MEMORY_LIMIT=512M